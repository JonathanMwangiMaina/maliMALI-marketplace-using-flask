# ============================================================================
# maliMALI Marketplace - Environment Variables Template
# ============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env (DO NOT commit .env to git)
# 2. Fill in your actual values
# 3. For PythonAnywhere, set these in Web tab > Environment Variables section
#
# ============================================================================

# ----------------------------------------------------------------------------
# SECURITY (REQUIRED)
# ----------------------------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
# SQLite (Default - for development/free tier)
DATABASE_URL=sqlite:///app.db

# MySQL (For production - PythonAnywhere paid plans)
# DATABASE_URL=mysql+pymysql://username:password@host.mysql.pythonanywhere-services.com/dbname

# PostgreSQL (Alternative)
# DATABASE_URL=postgresql://username:password@host/dbname

# ----------------------------------------------------------------------------
# FILE UPLOADS
# ----------------------------------------------------------------------------
VENDOR_UPLOAD_PATH=/path/to/uploads

# ----------------------------------------------------------------------------
# MPESA PAYMENT INTEGRATION (Required for payments)
# ----------------------------------------------------------------------------
# Get credentials from: https://developer.safaricom.co.ke/

# API Credentials
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret

# API Endpoints
# Sandbox: https://sandbox.safaricom.co.ke
# Production: https://api.safaricom.co.ke
MPESA_API_URL=https://sandbox.safaricom.co.ke

# Business Configuration
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASS_KEY=your-passkey-here
MPESA_PHONE_NUMBER=254712345678

# Transaction Configuration
MPESA_PARTY_A=174379
MPESA_PARTY_B=174379

# Initiator Configuration (for B2C/reversals)
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=your-initiator-password

# OAuth Configuration
MPESA_BASIC_AUTHORIZATION=auto-generated-or-manual
MPESA_GRANT_TYPE=client_credentials

# ----------------------------------------------------------------------------
# AFRICA'S TALKING INTEGRATION (Optional - for SMS/Airtime)
# ----------------------------------------------------------------------------
# Get credentials from: https://africastalking.com/
AFRICASTALKING_API_KEY=your-api-key
AT_USERNAME=sandbox

# ----------------------------------------------------------------------------
# GOOGLE MAPS API (Optional - for location features)
# ----------------------------------------------------------------------------
# Get API key from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ----------------------------------------------------------------------------
# IP INFO GEOLOCATION (Optional)
# ----------------------------------------------------------------------------
# Get token from: https://ipinfo.io/
IP_INFO_ACCESS_TOKEN=your-ipinfo-token

# ============================================================================
# DEPLOYMENT-SPECIFIC NOTES
# ============================================================================
#
# PYTHONANYWHERE:
# - Set these in Web tab > Environment Variables section
# - DO NOT put secrets in WSGI file
# - Use absolute paths for file uploads
#
# HEROKU:
# - Use `heroku config:set VAR=value`
# - DATABASE_URL is auto-set
#
# DOCKER:
# - Pass via docker-compose.yml or docker run -e
# - Use .env file with docker-compose
#
# LOCAL DEVELOPMENT:
# - Use .env file with python-dotenv
# - Never commit .env to version control
#
# ============================================================================

